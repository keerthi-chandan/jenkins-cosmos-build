pipeline {
    // No pipeline-level agent: each build stage explicitly runs on the
    // 'cosmos-builder' SSH agent; post-actions explicitly pick controller vs
    // agent. Workspace continuity across stages is fine because there is only
    // one node with the 'cosmos-builder' label.
    agent none

    environment {
        NOBLE_REPO     = 'https://github.com/strangelove-ventures/noble.git'
        NOBLE_VERSION  = 'v11.1.0-rc.1'

        AWS_REGION     = 'us-east-1'
        AWS_ACCOUNT_ID = credentials('aws-account-id')
        ECR_REPO       = 'cosmos/nobled'
        IMAGE_LOCAL    = "nobled:${env.BUILD_NUMBER}"
        IMAGE_REMOTE   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:${env.BUILD_NUMBER}"

        // Absolute PATH — do NOT interpolate ${env.PATH} here. The pipeline-level
        // environment {} block is evaluated on the controller at pipeline init,
        // so ${env.PATH} would be the controller's systemd-restricted PATH (often
        // missing /usr/local/bin), then exported to the agent — which causes the
        // durable-task wrapper's `nohup` lookup to fail silently ("process
        // apparently never started" after 5 min). Hardcoding the full system PATH
        // here guarantees the agent's sh wrapper can find nohup / sleep / sh / etc.
        // /var/lib/jenkins/go/bin is GOPATH/bin where `make install` deposits nobled.
        PATH           = "/usr/local/go/bin:/var/lib/jenkins/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        GOPATH         = '/var/lib/jenkins/go'
    }

    options {
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            agent { label 'cosmos-builder' }
            steps {
                sh '''
                    rm -rf noble
                    git clone --depth 1 --branch ${NOBLE_VERSION} ${NOBLE_REPO} noble
                '''
            }
        }

        stage('Build') {
            agent { label 'cosmos-builder' }
            steps {
                dir('noble') {
                    sh 'make install'
                    sh '${GOPATH}/bin/nobled version'
                }
            }
        }

        stage('Test') {
            agent { label 'cosmos-builder' }
            steps {
                dir('noble') {
                    sh 'go test ./... -timeout 15m'
                }
            }
        }

        stage('Lint') {
            agent { label 'cosmos-builder' }
            steps {
                dir('noble') {
                    // Report-only on upstream code we don't own; --issues-exit-code 0 keeps the build green.
                    sh 'golangci-lint run --timeout 10m --issues-exit-code 0 ./...'
                }
            }
        }

        stage('Security (gosec)') {
            agent { label 'cosmos-builder' }
            steps {
                dir('noble') {
                    // Same rationale as Lint — report-only against upstream Cosmos code.
                    sh 'gosec -severity medium -confidence medium -no-fail ./...'
                }
            }
        }

        stage('Docker Build') {
            agent { label 'cosmos-builder' }
            steps {
                sh '''
                    docker build \
                        -f jenkins/Dockerfile \
                        --build-arg NOBLE_REPO=${NOBLE_REPO} \
                        --build-arg NOBLE_VERSION=${NOBLE_VERSION} \
                        -t ${IMAGE_LOCAL} \
                        .
                '''
            }
        }

        stage('Trivy Scan') {
            agent { label 'cosmos-builder' }
            steps {
                // Report-only: most CVEs are in upstream base image + Cosmos deps.
                // Real-prod remediation = bump base image, bump Go toolchain, use
                // .trivyignore for reviewed CVEs. For now we surface the report.
                sh '''
                    trivy image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --no-progress \
                        ${IMAGE_LOCAL}
                '''
            }
        }

        stage('ECR Push') {
            agent { label 'cosmos-builder' }
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-ecr',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                        aws ecr get-login-password --region ${AWS_REGION} \
                            | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                        docker tag ${IMAGE_LOCAL} ${IMAGE_REMOTE}
                        docker push ${IMAGE_REMOTE}
                    '''
                }
            }
        }
    }

    post {
        // Slack notifications run on the controller (built-in node) — they only
        // need curl, and keeping them off the agent means a notification still
        // goes out if the agent itself is the thing that failed.
        success {
            node('built-in') {
                script {
                    try {
                        withCredentials([string(credentialsId: 'slack-webhook', variable: 'SLACK_URL')]) {
                            sh '''
                                curl -s -X POST -H 'Content-type: application/json' \
                                    --data "{\\"text\\":\\":white_check_mark: nobled #${BUILD_NUMBER} pushed: ${IMAGE_REMOTE}\\"}" \
                                    ${SLACK_URL} || true
                            '''
                        }
                    } catch (Exception e) {
                        echo "Slack notify skipped (slack-webhook credential not configured)"
                    }
                }
            }
        }
        failure {
            node('built-in') {
                script {
                    try {
                        withCredentials([string(credentialsId: 'slack-webhook', variable: 'SLACK_URL')]) {
                            sh '''
                                curl -s -X POST -H 'Content-type: application/json' \
                                    --data "{\\"text\\":\\":x: nobled #${BUILD_NUMBER} failed at stage ${STAGE_NAME}. ${BUILD_URL}\\"}" \
                                    ${SLACK_URL} || true
                            '''
                        }
                    } catch (Exception e) {
                        echo "Slack notify skipped (slack-webhook credential not configured)"
                    }
                }
            }
        }
        // Image cleanup must run on the agent — that's where the docker daemon lives now.
        always {
            node('cosmos-builder') {
                sh 'docker image prune -f --filter "label!=keep" || true'
            }
        }
    }
}
